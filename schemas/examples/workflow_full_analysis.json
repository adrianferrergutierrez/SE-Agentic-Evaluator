{
  "version": "1.0",
  "name": "workflow_full_analysis",
  "description": "Workflow complet amb anàlisi d'orfes, SMART i ISO 25010 abans d'avaluar",
  "variables": {
    "input_docx": "tests/test2/A1.2 Memoria trabajo final.docx",
    "input_rubric": "tests/test2/rubrica-hito-1.md",
    "output_dir": "tests/test2/output/full_analysis"
  },
  "steps": [
    {
      "id": "step_docx_extract",
      "tool": "docx_extract",
      "description": "Convertir document Word a Markdown amb extracció d'imatges",
      "params": {
        "input": "${input_docx}",
        "output_dir": "${output_dir}/phase0"
      },
      "output": {
        "document_md": "${step_docx_extract.result.contents_md}",
        "images": "${step_docx_extract.result.images}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_rubric_import",
      "tool": "rubric_importer",
      "description": "Importar rúbrica Markdown a configuració YAML",
      "params": {
        "input": "${input_rubric}",
        "output": "${output_dir}/rubric.yaml"
      },
      "output": {
        "config": "${step_rubric_import.result.config_path}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_extract_objectives",
      "tool": "extract_objectives",
      "description": "Extreure objectius del document",
      "params": {
        "document": "${step_docx_extract.output.document_md}"
      },
      "output": {
        "objectives_md": "${step_extract_objectives.result.markdown}"
      },
      "on_error": "skip"
    },
    {
      "id": "step_extract_requirements",
      "tool": "extract_requirements",
      "description": "Extreure requisits del document",
      "params": {
        "document": "${step_docx_extract.output.document_md}"
      },
      "output": {
        "requirements_md": "${step_extract_requirements.result.markdown}"
      },
      "on_error": "skip"
    },
    {
      "id": "step_extract_use_cases",
      "tool": "extract_use_cases",
      "description": "Extreure casos d'ús del document",
      "params": {
        "document": "${step_docx_extract.output.document_md}"
      },
      "output": {
        "use_cases_md": "${step_extract_use_cases.result.markdown}"
      },
      "on_error": "skip"
    },
    {
      "id": "step_detect_orphans",
      "tool": "detect_orphans",
      "description": "Detectar requisits i objectius orfes",
      "params": {
        "objectives_md": "${step_extract_objectives.output.objectives_md}",
        "requirements_md": "${step_extract_requirements.output.requirements_md}"
      },
      "output": {
        "orphans_report": "${step_detect_orphans.result.markdown}"
      },
      "on_error": "skip"
    },
    {
      "id": "step_evaluate_smart",
      "tool": "evaluate_smart",
      "description": "Avaluar objectius amb criteris SMART",
      "params": {
        "objectives_md": "${step_extract_objectives.output.objectives_md}"
      },
      "output": {
        "smart_report": "${step_evaluate_smart.result.markdown}"
      },
      "on_error": "skip"
    },
    {
      "id": "step_classify_iso25010",
      "tool": "classify_iso25010",
      "description": "Classificar requisits no funcionals segons ISO 25010",
      "params": {
        "requirements_md": "${step_extract_requirements.output.requirements_md}"
      },
      "output": {
        "iso_report": "${step_classify_iso25010.result.markdown}"
      },
      "on_error": "skip"
    },
    {
      "id": "step_build_context",
      "tool": "build_context",
      "description": "Construir context d'anàlisi per a l'avaluació",
      "params": {
        "objectives_md": "${step_extract_objectives.output.objectives_md}",
        "requirements_md": "${step_extract_requirements.output.requirements_md}",
        "use_cases_md": "${step_extract_use_cases.output.use_cases_md}",
        "orphans_report": "${step_detect_orphans.output.orphans_report}",
        "smart_report": "${step_evaluate_smart.output.smart_report}",
        "iso_report": "${step_classify_iso25010.output.iso_report}"
      },
      "output": {
        "context_md": "${step_build_context.result.markdown}"
      },
      "on_error": "skip"
    },
    {
      "id": "step_evaluate",
      "tool": "criterion_evaluator",
      "description": "Avaluar tots els criteris de la rúbrica amb context",
      "params": {
        "document": "${step_docx_extract.output.document_md}",
        "config": "${step_rubric_import.output.config}",
        "context": "${step_build_context.output.context_md}",
        "output_dir": "${output_dir}/evaluacion"
      },
      "output": {
        "scores": "${step_evaluate.result.scores}",
        "eval_dir": "${step_evaluate.result.output_dir}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_grade",
      "tool": "grader",
      "description": "Calcular nota ponderada final",
      "params": {
        "scores": "${step_evaluate.output.scores}",
        "config": "${step_rubric_import.output.config}"
      },
      "output": {
        "final_grade": "${step_grade.result.weighted_final}",
        "mean": "${step_grade.result.mean_xbar}",
        "level": "${step_grade.result.performance_level}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_report",
      "tool": "report_generator",
      "description": "Generar informe final d'avaluació",
      "params": {
        "document": "${step_docx_extract.output.document_md}",
        "eval_dir": "${step_evaluate.output.eval_dir}",
        "config": "${step_rubric_import.output.config}",
        "scores": "${step_evaluate.output.scores}",
        "output": "${output_dir}/evaluacion_final.md"
      },
      "on_error": "skip"
    }
  ]
}
