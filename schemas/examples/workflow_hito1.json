{
  "version": "1.0",
  "name": "workflow_hito1",
  "description": "Workflow per avaluar un Hito 1 (Requisits i Casos d'Ús)",
  "variables": {
    "input_docx": "tests/test2/A1.2 Memoria trabajo final.docx",
    "input_rubric": "tests/test2/rubrica-hito-1.md",
    "output_dir": "tests/test2/output"
  },
  "steps": [
    {
      "id": "step_docx_extract",
      "tool": "docx_extract",
      "description": "Convertir document Word a Markdown amb extracció d'imatges",
      "params": {
        "input": "${input_docx}",
        "output_dir": "${output_dir}/phase0"
      },
      "output": {
        "document_md": "${step_docx_extract.result.contents_md}",
        "images": "${step_docx_extract.result.images}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_rubric_import",
      "tool": "rubric_importer",
      "description": "Importar rúbrica Markdown a configuració YAML",
      "params": {
        "input": "${input_rubric}",
        "output": "${output_dir}/rubric.yaml"
      },
      "output": {
        "config": "${step_rubric_import.result.config_path}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_evaluate",
      "tool": "criterion_evaluator",
      "description": "Avaluar tots els criteris de la rúbrica amb context complet",
      "params": {
        "document": "${step_docx_extract.output.document_md}",
        "config": "${step_rubric_import.output.config}",
        "full": true,
        "output_dir": "${output_dir}/evaluacion"
      },
      "output": {
        "scores": "${step_evaluate.result.scores}",
        "eval_dir": "${step_evaluate.result.output_dir}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_grade",
      "tool": "grader",
      "description": "Calcular nota ponderada final",
      "params": {
        "scores": "${step_evaluate.output.scores}",
        "config": "${step_rubric_import.output.config}"
      },
      "output": {
        "final_grade": "${step_grade.result.weighted_final}",
        "mean": "${step_grade.result.mean_xbar}",
        "level": "${step_grade.result.performance_level}"
      },
      "on_error": "abort"
    },
    {
      "id": "step_report",
      "tool": "report_generator",
      "description": "Generar informe final d'avaluació",
      "params": {
        "document": "${step_docx_extract.output.document_md}",
        "eval_dir": "${step_evaluate.output.eval_dir}",
        "config": "${step_rubric_import.output.config}",
        "scores": "${step_evaluate.output.scores}",
        "output": "${output_dir}/evaluacion_final.md"
      },
      "on_error": "skip"
    }
  ]
}
